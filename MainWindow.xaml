<Window x:Class="VideoStreamSimulationTransmission.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="视频流模拟传输工具" Height="700" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl TabStripPlacement="Left">
            <!-- 数据模拟传输 -->
            <TabItem Header="数据模拟传输" MinWidth="100">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 通讯设置 -->
                    <GroupBox Header="通讯设置" Grid.Column="0" Grid.Row="0" Margin="5" Padding="10">
                        <StackPanel>
                            <ComboBox Name="cbDataType" Width="150" Margin="0,5" SelectedIndex="0">
                                <ComboBoxItem Content="TCP"/>
                                <ComboBoxItem Content="UDP"/>
                                <ComboBoxItem Content="串口"/>
                            </ComboBox>
                            
                            <!-- 角色选择 -->
                            <TextBlock Text="角色:" Margin="0,8,0,2"/>
                            <ComboBox Name="cbDataRole" Width="150" SelectedIndex="0" SelectionChanged="cbDataRole_SelectionChanged">
                                <ComboBoxItem Content="客户端"/>
                                <ComboBoxItem Content="服务端"/>
                            </ComboBox>

                            <!-- 客户端设置 -->
                            <StackPanel Name="pnlDataClient">
                                <TextBlock Text="服务端IP:" Margin="0,5"/>
                                <TextBox Name="txtRemoteIP" Width="150" Text="127.0.0.1"/>
                                <TextBlock Text="服务端端口:" Margin="0,5"/>
                                <TextBox Name="txtRemotePort" Width="150" Text="8080"/>
                            </StackPanel>
                            
                            <!-- 服务端设置 -->
                            <StackPanel Name="pnlDataServer" Visibility="Collapsed">
                                <TextBlock Text="本地监听端口:" Margin="0,5"/>
                                <TextBox Name="txtLocalPort" Width="150" Text="8080"/>
                            </StackPanel>
                            
                            <!-- 串口设置 -->
                            <StackPanel Name="pnlSerial" Visibility="Collapsed">
                                <TextBlock Text="串口:" Margin="0,5"/>
                                <ComboBox Name="cbSerialPort" Width="150"/>
                                <TextBlock Text="波特率:" Margin="0,5"/>
                                <ComboBox Name="cbBaudRate" Width="150" SelectedIndex="3">
                                    <ComboBoxItem Content="9600"/>
                                    <ComboBoxItem Content="19200"/>
                                    <ComboBoxItem Content="38400"/>
                                    <ComboBoxItem Content="115200"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Button Name="btnConnect" Content="连接" Width="70" Click="btnConnect_Click"/>
                                <Button Name="btnDisconnect" Content="断开" Width="70" Margin="5,0" IsEnabled="False" Click="btnDisconnect_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- 数据发送 -->
                    <GroupBox Header="数据发送" Grid.Column="0" Grid.Row="1" Margin="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="发送内容:" Margin="0,5"/>
                            <TextBox Name="txtSendData" Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            <Button Name="btnSend" Content="发送" Width="150" Margin="0,10" Click="btnSend_Click" IsEnabled="False"/>
                            <CheckBox Name="chkHexSend" Content="十六进制发送" Margin="0,5"/>
                            <CheckBox Name="chkAutoSend" Content="定时发送" Margin="0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="间隔(ms):" VerticalAlignment="Center"/>
                                <TextBox Name="txtInterval" Width="80" Text="1000" Margin="5,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- 数据接收 -->
                    <GroupBox Header="数据接收" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Margin="5" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox Name="chkHexDisplay" Content="十六进制显示" Margin="5,0"/>
                                <CheckBox Name="chkAutoScroll" Content="自动滚动" IsChecked="True" Margin="5,0"/>
                                <Button Name="btnClear" Content="清空" Width="60" Margin="10,0" Click="btnClear_Click"/>
                            </StackPanel>
                            <TextBox Name="txtReceiveData" Grid.Row="1" IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                                     HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                        </Grid>
                    </GroupBox>

                    <!-- 状态栏 -->
                    <StatusBar Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2">
                        <StatusBarItem>
                            <TextBlock Name="txtStatus" Text="未连接"/>
                        </StatusBarItem>
                        <Separator/>
                        <StatusBarItem>
                            <TextBlock Name="txtTXCount" Text="TX: 0"/>
                        </StatusBarItem>
                        <StatusBarItem>
                            <TextBlock Name="txtRXCount" Text="RX: 0"/>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </TabItem>

            <!-- 视频模拟传输 -->
            <TabItem Header="视频模拟传输" MinWidth="100">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 功能选择 -->
                    <Border BorderBrush="DarkGray" Grid.Column="0" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                        <StackPanel Width="150">
                            <TextBlock Text="功能选择" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,10"/>
                            <RadioButton Name="rbVideoFile" Content="视频文件发送" GroupName="VideoSource" IsChecked="True" Margin="5"/>
                            <RadioButton Name="rbCamera" Content="摄像头发送" GroupName="VideoSource" Margin="5"/>
                            <RadioButton Name="rbReceive" Content="视频接收" GroupName="VideoSource" Margin="5"/>
                            
                            <Separator Margin="0,10"/>
                            
                            <TextBlock Text="视频源" Margin="0,5"/>
                            <Button Name="btnSelectVideo" Content="选择视频文件" Width="130" Margin="0,5" Click="btnSelectVideo_Click"/>
                            <TextBlock Name="txtVideoPath" Text="未选择" TextWrapping="Wrap" Margin="0,5" FontSize="10"/>
                            
                            <TextBlock Text="摄像头" Margin="0,10,0,5"/>
                            <ComboBox Name="cbCamera" Width="130" Margin="0,5"/>
                            
                            <Separator Margin="0,10"/>
                            
                            <Button Name="btnStartVideo" Content="开始传输" Width="130" Margin="0,5" Click="btnStartVideo_Click"/>
                            <Button Name="btnStopVideo" Content="停止传输" Width="130" Margin="0,5" IsEnabled="False" Click="btnStopVideo_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- 通讯设置 -->
                    <Border BorderBrush="DarkGray" Grid.Column="1" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                        <StackPanel Width="180">
                            <TextBlock Text="通讯设置" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="传输协议:" Margin="0,5"/>
                            <ComboBox Name="cbVideoProtocol" Width="160" SelectedIndex="0" SelectionChanged="cbVideoProtocol_SelectionChanged">
                                <ComboBoxItem Content="UDP"/>
                                <ComboBoxItem Content="TCP"/>
                            </ComboBox>
                            
                            <TextBlock Text="角色:" Margin="0,8,0,2"/>
                            <ComboBox Name="cbVideoRole" Width="160" SelectedIndex="0" SelectionChanged="cbVideoRole_SelectionChanged">
                                <ComboBoxItem Content="客户端(发送)"/>
                                <ComboBoxItem Content="服务端(接收)"/>
                            </ComboBox>
                            
                            <!-- 视频客户端设置 -->
                            <StackPanel Name="pnlVideoClient">
                                <TextBlock Text="服务端IP:" Margin="0,5"/>
                                <TextBox Name="txtVideoRemoteIP" Width="160" Text="127.0.0.1"/>
                                <TextBlock Text="服务端端口:" Margin="0,5"/>
                                <TextBox Name="txtVideoRemotePort" Width="160" Text="9000"/>
                            </StackPanel>
                            
                            <!-- 视频服务端设置 -->
                            <StackPanel Name="pnlVideoServer" Visibility="Collapsed">
                                <TextBlock Text="本地监听端口:" Margin="0,5"/>
                                <TextBox Name="txtVideoLocalPort" Width="160" Text="9000"/>
                            </StackPanel>
                            
                            <TextBlock Text="视频质量(1-100):" Margin="0,10,0,5"/>
                            <Slider Name="sldQuality" Minimum="1" Maximum="100" Value="80" Width="160"/>
                            <TextBlock Name="txtQuality" Text="80" HorizontalAlignment="Center"/>
                            
                            <TextBlock Text="帧率(FPS):" Margin="0,10,0,5"/>
                            <ComboBox Name="cbFPS" Width="160" SelectedIndex="2">
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="15"/>
                                <ComboBoxItem Content="30"/>
                                <ComboBoxItem Content="60"/>
                            </ComboBox>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,15">
                                <Button Name="btnVideoConnect" Content="连接" Width="70" Click="btnVideoConnect_Click"/>
                                <Button Name="btnVideoDisconnect" Content="断开" Width="70" Margin="5,0" IsEnabled="False" Click="btnVideoDisconnect_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 视频显示 -->
                    <Border BorderBrush="DarkGray" Grid.Column="2" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="视频预览" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,10"/>
                            
                            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Background="Black">
                                <Grid>
                                    <Image Name="imgVideo" Stretch="Uniform"/>
                                    <TextBlock Name="txtVideoInfo" Text="等待视频源..." HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                </Grid>
                            </Border>
                            
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10">
                                <TextBlock Name="txtVideoStatus" Text="状态: 未连接" VerticalAlignment="Center"/>
                                <TextBlock Name="txtFrameCount" Text="帧数: 0" Margin="20,0" VerticalAlignment="Center"/>
                                <TextBlock Name="txtBitrate" Text="码率: 0 KB/s" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
